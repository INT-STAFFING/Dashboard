# Neon serverless Postgres connection string.
# La Vercel ⇄ Neon integration la espone come DATABASE_URL (e POSTGRES_URL).
# Esempio: postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# (opzionale) connessione non-pooled, usata da drizzle-kit per le migrazioni
DATABASE_URL_UNPOOLED=

# Secret richiesto per la pagina /upload e per POST /api/upload
UPLOAD_SECRET=cambia_questo_in_produzione

# Secret usato per firmare i cookie di sessione (login). In mancanza usa
# UPLOAD_SECRET o un default insicuro: IMPOSTALO in produzione.
AUTH_SECRET=cambia_questo_in_produzione

# Credenziali dell'amministratore iniziale (creato automaticamente al primo
# avvio). L'account ADMIN non può essere eliminato.
ADMIN_EMAIL=admin@dashboard.local
ADMIN_PASSWORD=admin
ADMIN_NAME=Amministratore
